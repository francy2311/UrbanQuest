<section class="page-header">
  <h1>Classifica</h1>
  <p>
    Gli utenti vengono ordinati in base ai punti ottenuti completando missioni approvate.
  </p>
</section>

{{#if users}}
<section class="leaderboard-card">
  <div class="leaderboard-header">
    <span>Posizione</span>
    <span>Utente</span>
    <span>Punti</span>
  </div>

  {{#each users}}
  <div class="leaderboard-row">
    <div class="leaderboard-position">
      #{{inc @index}}
    </div>

    <div class="leaderboard-user">
      {{#if profile_image_path}}
      <img class="avatar-img" src="{{profile_image_path}}" alt="Foto profilo">
      {{else}}
      <div class="avatar">
        {{initial name}}
      </div>
      {{/if}}

      <div>
        <strong>{{name}}</strong>
        <p>{{email}}</p>
      </div>
    </div>

    <div class="leaderboard-points">
      {{points}} pt
    </div>
  </div>
  {{/each}}
</section>
{{else}}
<div class="empty-state">
  <p>Non ci sono ancora utenti in classifica.</p>
</div>
{{/if}}
