<section class="auth-page">
  <div class="auth-card">
    <h1>Accedi</h1>
    <p>Entra nel tuo account UrbanQuest.</p>

    <form action="/login" method="post" class="form">
      <div class="form-group">
        <label for="email">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="mario@email.it"
          required
        >
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          placeholder="Password"
          required
        >
      </div>

      <button class="btn full-width" type="submit">Login</button>
    </form>

    <div class="test-credentials">
      <strong>Credenziali di test:</strong>
      <p>admin@urbanquest.it / password123</p>
      <p>mario@urbanquest.it / password123</p>
    </div>

    <p class="auth-switch">
      Non hai un account?
      <a href="/register">Registrati</a>
    </p>
  </div>
</section>
