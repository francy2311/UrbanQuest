<section class="page-header narrow-page">
  <p class="eyebrow-dark">Dettaglio missione</p>
  <h1>{{mission.title}}</h1>
  <p>{{mission.description}}</p>
</section>

<section class="detail-card detail-card-centered">
  <div class="mission-meta">
    {{#if mission.category_name}}
    <span class="badge">{{mission.category_name}}</span>
    {{else}}
    <span class="badge">Senza categoria</span>
    {{/if}}

    <span class="badge badge-green">{{mission.points}} punti</span>
    <span class="badge badge-yellow">{{mission.difficulty}}</span>
    <span class="badge">{{mission.status}}</span>
  </div>

  <div class="detail-grid">
    <div>
      <h2>Informazioni missione</h2>

      <p>
        <strong>Zona:</strong>
        {{mission.zone}}
      </p>

      {{#if mission.address}}
      <p>
        <strong>Indirizzo:</strong>
        {{mission.address}}
      </p>
      {{else}}
      <p>
        <strong>Indirizzo:</strong>
        Non specificato
      </p>
      {{/if}}

      <p>
        <strong>Creatore:</strong>
        {{mission.creator_name}}
      </p>

      <p>
        <strong>Data creazione:</strong>
        {{mission.created_at}}
      </p>
    </div>

    <div class="action-box">
      <h2>Completa la sfida</h2>

      <p>
        Accetta la missione, completala nel mondo reale e invia una prova.
        Il creatore potrà approvarla o rifiutarla.
      </p>

      {{#if currentUser}}
      {{#if (eq currentUser.id mission.creator_id)}}
      <div class="info-box">
        Sei il creatore di questa missione, quindi non puoi accettarla.
      </div>
      {{else}}
      <form action="/missions/{{mission.id}}/accept" method="post">
        <button class="btn" type="submit">Accetta missione</button>
      </form>
      {{/if}}
      {{else}}
      <a class="btn" href="/login">Accedi per accettare</a>
      {{/if}}
    </div>
  </div>
</section>
